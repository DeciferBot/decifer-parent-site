# Early-access form: email notification
# Get your key from https://resend.com/api-keys
# Without this, form submissions are logged to Vercel Function logs only.
RESEND_API_KEY=

# Early-access form: Supabase storage (optional)
# Uncomment the Supabase block in src/app/api/early-access/route.ts to activate.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics provider ID (optional)
# Add the corresponding script tag to src/app/layout.tsx.
NEXT_PUBLIC_ANALYTICS_ID=
