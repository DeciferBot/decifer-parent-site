# Early-access form: email notification
# Get your key from https://resend.com/api-keys
# Without this, form submissions are logged to Vercel Function logs only.
RESEND_API_KEY=

# Email address to receive early-access notifications.
# Set to any working inbox you control (e.g. your personal email until hello@decifer.io is ready).
RESEND_NOTIFY_EMAIL=

# Sending address for notification emails.
# Must be a verified domain in Resend (https://resend.com/domains).
# Leave blank to use Resend's shared test address (onboarding@resend.dev) while testing.
# Set to e.g. "DECIFER <noreply@decifer.io>" once decifer.io is verified in Resend.
RESEND_FROM=

# Early-access form: Supabase storage (optional)
# Uncomment the Supabase block in src/app/api/early-access/route.ts to activate.
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Analytics provider ID (optional)
# Add the corresponding script tag to src/app/layout.tsx.
NEXT_PUBLIC_ANALYTICS_ID=

# Stripe (https://dashboard.stripe.com/apikeys)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
